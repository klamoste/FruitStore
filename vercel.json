{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "USE_DATABASE_URL=0 VERCEL_USE_POSTGRES=0 STATIC_ROOT=.vercel_static python manage.py collectstatic --noinput",
  "functions": {
    "api/index.py": {
      "includeFiles": "{fruit_store/**,templates/**,.vercel_static/**,db.sqlite3}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
